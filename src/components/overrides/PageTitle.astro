---
/**
 * 覆盖 Starlight 的 PageTitle 组件
 * 在 H1 前渲染终端 cat 命令行 + YAML 前置元数据卡片
 */
const PAGE_TITLE_ID = '_top';
const { entry } = Astro.locals.starlightRoute;
const title: string = entry.data.title ?? '';

// 从 URL 推导文件名和目录（更可靠，不依赖 entry.id 格式）
const pathname = Astro.url.pathname.replace(/^\/|\/$/g, '');
const segments = pathname.split('/').filter(Boolean);
const slug = segments[segments.length - 1] ?? '';
const filename = slug + '.md';
const category = segments.length > 1 ? segments[0] : '';

// 自定义 frontmatter 字段
const data = entry.data as Record<string, unknown>;
const date: string = typeof data.date === 'string' ? data.date : '';
const tags: string[] = Array.isArray(data.tags) ? (data.tags as string[]) : [];
---

<!-- 终端 cat 命令行 -->
<div class="cat-prompt">
  <span class="cp-user">yuxiang</span><span class="cp-dim">@</span><span class="cp-host">blog</span>{category && <span class="cp-dim"> ~/{category}</span>}<span class="cp-dim"> ❯ cat </span><span class="cp-file">{filename}</span>
</div>

<!-- YAML 前置元数据卡片 -->
<div class="frontmatter-card">
  <div class="fm-sep">---</div>
  <div class="fm-row">
    <span class="fm-key">title:</span>
    <span class="fm-val fm-title">"{title}"</span>
  </div>
  {date && (
    <div class="fm-row">
      <span class="fm-key">date: </span>
      <span class="fm-val">{date}</span>
    </div>
  )}
  {tags.length > 0 && (
    <div class="fm-row">
      <span class="fm-key">tags: </span>
      <span class="fm-val">[<span class="fm-tags">{tags.map((t, i) => <span class="fm-tag">{t}{i < tags.length - 1 ? ', ' : ''}</span>)}</span>]</span>
    </div>
  )}
  <div class="fm-sep">---</div>
</div>

<h1 id={PAGE_TITLE_ID}>{title}</h1>

<!-- 隐藏元数据供 JS 读取（Neovim 状态栏注入用） -->
<div id="article-meta"
  data-filename={filename}
  data-category={category}
  data-date={date}
  data-tags={tags.join(',')}
  hidden></div>

<style>
  h1 {
    margin-top: 0.3rem;
    margin-bottom: 0.95rem;
    font-size: clamp(2.55rem, 4vw, 3.15rem);
    line-height: 1.08;
    font-weight: 600;
    color: var(--sl-color-white);
    max-width: 17.5ch;
    text-wrap: balance;
    letter-spacing: -0.028em;
  }
</style>
