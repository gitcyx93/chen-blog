---
/**
 * 覆盖 Starlight 的 PageTitle 组件
 * 在 H1 标题上方注入终端风格路径行：
 * yuxiang@blog ~/ / psychology / 文章标题
 */
const PAGE_TITLE_ID = '_top';

const { entry } = Astro.locals.starlightRoute;
const title: string = entry.data.title ?? '';

// 从 URL 提取目录层级（去掉首尾斜杠，取最后一段之前的部分）
const pathname = Astro.url.pathname.replace(/^\/|\/$/g, '');
const segments = pathname.split('/').filter(Boolean);
const dirs = segments.slice(0, -1); // 去掉最后一段（文章 slug），只保留目录
---

<div class="terminal-path">
  <span class="tp-user">yuxiang</span><span class="tp-dim">@</span><span class="tp-host">blog</span><span class="tp-dim"> ~/</span>
  {dirs.map(dir => (
    <span><span class="tp-sep"> / </span><span class="tp-dir">{dir}</span></span>
  ))}
  {title && (
    <span><span class="tp-sep"> / </span><span class="tp-title">{title}</span></span>
  )}
</div>

<h1 id={PAGE_TITLE_ID}>{title}</h1>

<style>
  .terminal-path {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.76rem;
    color: var(--text-muted);
    padding: 0.5rem 0;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.4;
  }

  .tp-user  { color: var(--color-green); }
  .tp-host  { color: var(--color-blue);  }
  .tp-dim   { color: var(--text-muted);  }
  .tp-sep   { color: var(--text-muted);  }
  .tp-dir   { color: var(--color-blue);  }
  .tp-title { color: var(--text-body);   }

  h1 {
    margin-top: 1rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>

<script>
  // 当原始路径条滚出视口，在顶栏正下方出现一条 fixed 克隆条
  (function () {
    const original = document.querySelector('.terminal-path') as HTMLElement | null;
    if (!original) return;

    // 创建 fixed 克隆条
    // top 用 CSS 变量，确保与顶栏高度对齐；初始 hidden
    const fixed = document.createElement('div');
    fixed.setAttribute('aria-hidden', 'true');
    fixed.innerHTML = original.innerHTML;
    fixed.className = 'terminal-path-fixed';
    fixed.style.cssText = `
      position: fixed;
      top: var(--sl-nav-height, 4rem);
      left: 0; right: 0;
      z-index: 50;
      background: var(--bg-base);
      padding: 0.45rem 1.5rem;
      border-bottom: 1px solid var(--border, rgba(255,255,255,0.08));
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      font-size: 0.76rem;
      font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
      line-height: 1.4;
      color: var(--text-muted);
      visibility: hidden;
      opacity: 0;
      transform: translateY(-6px);
      transition: opacity 0.18s ease, transform 0.18s ease;
    `;
    document.body.appendChild(fixed);

    // scroll 事件：原始条顶部滚过视口顶部时显示 fixed 条
    let visible = false;
    const update = () => {
      // 动态读取顶栏高度（避免初始值为 0 的竞争问题）
      const navH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--sl-nav-height')) * 16 || 64;
      const shouldShow = original.getBoundingClientRect().bottom < navH + 4;
      if (shouldShow !== visible) {
        visible = shouldShow;
        if (visible) {
          fixed.style.visibility = 'visible';
          fixed.style.opacity = '1';
          fixed.style.transform = 'translateY(0)';
        } else {
          fixed.style.opacity = '0';
          fixed.style.transform = 'translateY(-6px)';
          // 等动画结束再隐藏
          setTimeout(() => { if (!visible) fixed.style.visibility = 'hidden'; }, 180);
        }
      }
    };

    window.addEventListener('scroll', update, { passive: true });
    // 延迟初始检查，确保布局已完成
    requestAnimationFrame(update);
  })();
</script>
