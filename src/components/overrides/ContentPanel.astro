---
/**
 * 覆盖 Starlight 的 ContentPanel 组件
 * - 在正文上方显示封面图（cover frontmatter）
 * - 在正文下方注入 BacklinksPanel（反向链接）
 */
import Default from '@astrojs/starlight/components/ContentPanel.astro';
import BacklinksPanel from '../BacklinksPanel.astro';
import type { Props } from '@astrojs/starlight/props';

const { entry } = Astro.props as Props;
const cover = (entry?.data as any)?.cover as string | undefined;
---

{cover && (
  <div class="article-cover-wrapper">
    <img src={cover} alt="" class="article-cover" loading="lazy" />
  </div>
)}

<Default {...Astro.props}>
  <slot />
</Default>

<BacklinksPanel />
