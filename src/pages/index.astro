---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const dirs = [
  { name: '文章/',   desc: '长文，值得反复阅读',   meta: '12 篇', href: '/blog' },
  { name: '笔记/',   desc: '日常碎片与即时观察',   meta: '',      href: '/psychology/human-vs-ai/' },
  { name: '工具箱/', desc: '正在用的工具推荐',     meta: ' 9 项', href: '/tools' },
];
---

<StarlightPage
  frontmatter={{ title: '陈的笔记', description: '这里不用登录，没有广告，没有算法，没有审查。你不是产品。', tableOfContents: false }}
  hasSidebar={false}
  headings={[]}
>
  <div class="home">
    <div class="terminal-window">

      <div class="terminal-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="terminal-title">~/ 陈的笔记</span>
      </div>

      <div class="terminal-body">

        <div class="line">
          <span class="path-user">yuxiang</span><span class="dim">@</span><span class="path-host">blog</span><span class="dim"> ~/</span>
        </div>
        <div class="line cmd-line">
          <span class="prompt">❯&nbsp;</span><span id="typed-text"></span><span class="cursor" id="cursor-1">█</span>
        </div>

        <div class="line output-block" id="output-sub">
          <span class="dim"># 这里不用登录，没有广告，没有算法，没有审查。</span><br/>
          <span class="manifesto">你不是产品。</span>&nbsp;<a href="/about" class="link">了解这个站点 →</a>
        </div>

        <div class="line spacer" id="spacer-ls"></div>

        <div class="line cmd-line" id="ls-prompt">
          <span class="prompt">❯&nbsp;</span><span class="typed-ls"></span><span class="cursor" id="cursor-ls">█</span>
        </div>

        <div class="ls-output" id="ls-output">
          {dirs.map(d => (
            <a href={d.href} class="ls-entry" data-name={d.name}>
              <span class="ls-name">{d.name}</span>
              <span class="ls-desc">{d.desc}</span>
              <span class="ls-meta">{d.meta}</span>
            </a>
          ))}
        </div>

        <div class="line spacer" id="spacer-end"></div>
        <div class="line cmd-line" id="final-cursor-line">
          <span class="prompt">❯&nbsp;</span><span class="cursor">█</span>
        </div>

      </div>
    </div>
  </div>
</StarlightPage>

<script>
  const typedEl   = document.getElementById('typed-text') as HTMLElement;
  const cursor1   = document.getElementById('cursor-1') as HTMLElement;
  const outputSub = document.getElementById('output-sub') as HTMLElement;
  const spacerLs  = document.getElementById('spacer-ls') as HTMLElement;
  const lsCmd     = document.getElementById('ls-cmd') as HTMLElement;
  const lsPrompt  = document.getElementById('ls-prompt') as HTMLElement;
  const lsTyped   = lsPrompt.querySelector('.typed-ls') as HTMLElement;
  const cursorLs  = document.getElementById('cursor-ls') as HTMLElement;
  const lsOutput  = document.getElementById('ls-output') as HTMLElement;
  const spacerEnd = document.getElementById('spacer-end') as HTMLElement;
  const finalCursorLine = document.getElementById('final-cursor-line') as HTMLElement;

  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  const segments = [
    { text: '你好，人类，欢迎你', hl: false },
    { text: '选择',              hl: true  },
    { text: '走进来',            hl: false },
  ];

  async function typeText(el: HTMLElement, text: string, speed = 80) {
    for (const ch of [...text]) {
      const s = document.createElement('span');
      s.textContent = ch;
      el.appendChild(s);
      await sleep(speed + Math.random() * 40);
    }
  }

  async function run() {
    await sleep(300);

    for (const seg of segments) {
      if (seg.hl) await sleep(400);
      for (const ch of [...seg.text]) {
        const s = document.createElement('span');
        if (seg.hl) s.className = 'hl';
        s.textContent = ch;
        typedEl.appendChild(s);
        await sleep(seg.hl ? 150 : 65 + Math.random() * 50);
      }
      if (seg.hl) await sleep(360);
    }

    cursor1.style.display = 'none';
    await sleep(300);
    outputSub.classList.add('show');

    await sleep(600);
    spacerLs.classList.add('show');
    await sleep(200);
    lsPrompt.classList.add('show');

    await sleep(300);
    await typeText(lsTyped, 'ls', 120);
    await sleep(200);

    cursorLs.style.display = 'none';
    lsOutput.classList.add('show');
    const entries = lsOutput.querySelectorAll<HTMLElement>('.ls-entry');
    entries.forEach((entry, i) => {
      setTimeout(() => entry.classList.add('show'), i * 100);
    });

    await sleep(entries.length * 100 + 200);
    spacerEnd.classList.add('show');
    await sleep(200);
    finalCursorLine.classList.add('show');
  }

  run();
</script>

<style>
  :global(header.header) { display: none; }
  :global(.main-frame) { padding-top: 0 !important; }
  :global(#_top) { display: none; }
  :global(.sl-markdown-content > hr:first-of-type) { display: none; }

  .home {
    padding: 3rem 0 4rem;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
  }

  .terminal-window {
    width: min(780px, 100%);
    background: #2e3440;
    border-radius: 10px;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.07), 0 20px 60px rgba(0,0,0,0.5);
    overflow: hidden;
  }

  .terminal-titlebar {
    background: #3b4252;
    padding: 11px 16px;
    display: flex;
    gap: 7px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }
  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.73rem;
    color: #4c566a;
    user-select: none;
  }

  .terminal-body {
    padding: 18px 24px 28px;
    font-size: clamp(0.875rem, 2.2vw, 1rem);
    line-height: 1.75;
    color: #d8dee9;
  }

  .line {
    display: none;
    white-space: pre-wrap;
  }
  .line:nth-child(1),
  .line:nth-child(2) { display: block; }
  .line.show { display: block; }

  .path-user  { color: #a3be8c; }
  .path-host  { color: #81a1c1; }
  .dim        { color: #4c566a; }
  .prompt     { color: #a3be8c; user-select: none; }

  :global(.hl) {
    color: #ebcb8b;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .cursor {
    color: #b48ead;
    animation: blink 0.85s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .output-block {
    margin-top: 6px;
    margin-bottom: 4px;
    color: #4c566a;
    opacity: 0;
    transition: opacity 0.7s ease-out;
  }
  .output-block.show { opacity: 1; }

  .manifesto {
    color: #eceff4;
    font-weight: 600;
  }

  .link {
    color: #88c0d0;
    text-decoration: none;
    border-bottom: 1px solid rgba(136,192,208,0.3);
    transition: border-color 0.15s;
  }
  .link:hover { border-color: #88c0d0; }

  .spacer { margin-top: 8px; }

  .ls-output {
    display: none;
    margin-top: 4px;
    margin-bottom: 4px;
  }
  .ls-output.show { display: block; }

  .ls-entry {
    display: grid !important;
    grid-template-columns: 10ch 1fr 6ch;
    gap: 0 1.5ch;
    padding: 2px 0;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.3s ease-out, transform 0.3s ease-out, background 0.15s;
    border-radius: 3px;
  }
  .ls-entry.show { opacity: 1; transform: translateX(0); }
  .ls-entry:hover { background: rgba(255,255,255,0.04); }

  .ls-name { color: #81a1c1; font-weight: 600; }
  .ls-desc { color: #4c566a; }
  .ls-meta { color: #434c5e; text-align: right; }

  @media (max-width: 480px) {
    .ls-entry { grid-template-columns: 9ch 1fr; }
    .ls-meta { display: none; }
  }
</style>
