---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{ title: '陈的笔记', description: '这里不用登录，没有广告，没有算法，没有审查。你不是产品。', tableOfContents: false }}
  hasSidebar={false}
  headings={[]}
>
  <div class="home">
    <div class="ide-window">

      <!-- ── 标题栏 ── -->
      <div class="ide-titlebar">
        <div class="ide-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="ide-title">陈的笔记 — README.md</span>
        <div class="ide-dots-placeholder"></div>
      </div>

      <!-- ── 主体：活动栏 + 侧边栏 + 编辑器 ── -->
      <div class="ide-layout">

        <!-- 活动栏 -->
        <div class="ide-activity-bar">
          <button class="activity-btn active" title="文件管理器">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M3 6h18M3 12h18M3 18h18"/>
            </svg>
          </button>
          <button class="activity-btn" title="搜索">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </div>

        <!-- 文件树侧边栏 -->
        <div class="ide-sidebar">
          <div class="sidebar-header">EXPLORER</div>
          <div class="sidebar-tree">
            <div class="tree-root">
              <span class="tree-arrow">▾</span>
              <span class="tree-folder-name">陈的笔记</span>
            </div>
            <div class="tree-item file active">
              <span class="tree-indent"></span>
              <span class="tree-file-icon">≡</span>
              <span>README.md</span>
            </div>
            <div class="tree-item folder">
              <span class="tree-indent"></span>
              <span class="tree-folder-icon">▸</span>
              <a href="/blog">文章</a>
            </div>
            <div class="tree-item folder">
              <span class="tree-indent"></span>
              <span class="tree-folder-icon">▸</span>
              <a href="/psychology/human-vs-ai/">笔记</a>
            </div>
            <div class="tree-item folder">
              <span class="tree-indent"></span>
              <span class="tree-folder-icon">▸</span>
              <a href="/tools">工具箱</a>
            </div>
          </div>
        </div>

        <!-- 编辑器区域 -->
        <div class="ide-editor">

          <!-- 标签栏 -->
          <div class="ide-tabs">
            <div class="tab active">
              <span class="tab-dot"></span>
              <span class="tab-name">README.md</span>
            </div>
          </div>

          <!-- 面包屑 -->
          <div class="ide-breadcrumb">
            <span class="bc-dim">陈的笔记</span>
            <span class="bc-sep"> › </span>
            <span class="bc-current">README.md</span>
          </div>

          <!-- 正文（带行号） -->
          <div class="ide-content">
            <div class="line-numbers" aria-hidden="true">
              {Array.from({length: 20}, (_, i) => <span>{i + 1}</span>)}
            </div>
            <div class="editor-body">
              <p class="md-h1"><span class="md-marker"># </span>你好，人类</p>
              <p class="md-h2"><span class="md-marker">## </span>欢迎你<span class="hl">选择</span>走进来</p>
              <p class="md-blank"></p>
              <p class="md-blockquote">
                <span class="md-marker">&gt; </span>这里不用登录，没有广告，没有算法，没有审查。<br/>
                <span class="md-marker">&gt; </span>你不是产品。<a href="/about" class="md-link">[了解这个站点](/about)</a>
              </p>
              <p class="md-blank"></p>
              <p class="md-hr"><span class="md-marker">---</span></p>
              <p class="md-blank"></p>
              <p class="md-h2"><span class="md-marker">## </span>目录</p>
              <p class="md-blank"></p>
              <p class="md-li">
                <span class="md-marker">- </span>
                <a href="/blog" class="md-link-inline">[文章]</a>
                <span class="md-link-url">(/blog)</span>
                <span class="md-comment"> — 长文，值得反复阅读</span>
              </p>
              <p class="md-li">
                <span class="md-marker">- </span>
                <a href="/psychology/human-vs-ai/" class="md-link-inline">[笔记]</a>
                <span class="md-link-url">(/notes)</span>
                <span class="md-comment"> — 日常碎片与即时观察</span>
              </p>
              <p class="md-li">
                <span class="md-marker">- </span>
                <a href="/tools" class="md-link-inline">[工具箱]</a>
                <span class="md-link-url">(/tools)</span>
                <span class="md-comment"> — 正在用的工具推荐</span>
              </p>
              <p class="md-blank"></p>
            </div>
          </div>

        </div>
      </div>

      <!-- ── 状态栏 ── -->
      <div class="ide-statusbar">
        <div class="status-left">
          <span class="status-branch">⎇&nbsp;main</span>
        </div>
        <div class="status-right">
          <span>UTF-8</span>
          <span>Markdown</span>
          <span>Ln 1, Col 1</span>
        </div>
      </div>

    </div>
  </div>
</StarlightPage>

<style>
  /* ══ 隐藏 Starlight 自动元素 ══ */
  :global(header.header) { display: none; }
  :global(.main-frame) { padding-top: 0 !important; }
  :global(#_top) { display: none; }
  :global(.sl-markdown-content > hr:first-of-type) { display: none; }
  :global(.sl-markdown-content p) { margin: 0 !important; }

  .home {
    padding: 3rem 0 4rem;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
  }

  /* ══ IDE 外框 ══ */
  .ide-window {
    width: min(920px, 100%);
    background: #1a1b26;
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.07),
      0 24px 64px rgba(0,0,0,0.6);
    display: flex;
    flex-direction: column;
  }

  /* 标题栏 */
  .ide-titlebar {
    background: #16161e;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
  }
  .ide-dots, .ide-dots-placeholder {
    display: flex;
    gap: 7px;
    width: 60px;
  }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }
  .ide-title {
    font-size: 0.73rem;
    color: #565f89;
    user-select: none;
  }

  /* ── 主体布局 ── */
  .ide-layout {
    display: grid;
    grid-template-columns: 44px 180px 1fr;
    min-height: 440px;
  }

  /* 活动栏 */
  .ide-activity-bar {
    background: #16161e;
    border-right: 1px solid rgba(255,255,255,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0;
    gap: 4px;
  }
  .activity-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #3b4261;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .activity-btn.active,
  .activity-btn:hover { color: #c0caf5; }

  /* 文件树侧边栏 */
  .ide-sidebar {
    background: #1a1b26;
    border-right: 1px solid rgba(255,255,255,0.05);
    font-size: 0.78rem;
    overflow: hidden;
  }
  .sidebar-header {
    padding: 10px 12px 6px;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: #3b4261;
    user-select: none;
  }
  .tree-root {
    padding: 3px 12px;
    display: flex;
    align-items: center;
    gap: 4px;
    color: #c0caf5;
    font-weight: 600;
    font-size: 0.8rem;
  }
  .tree-arrow { color: #565f89; font-size: 0.7rem; }
  .tree-item {
    padding: 3px 12px 3px 20px;
    display: flex;
    align-items: center;
    gap: 5px;
    color: #a9b1d6;
    cursor: pointer;
    transition: background 0.1s;
    white-space: nowrap;
  }
  .tree-item:hover { background: rgba(255,255,255,0.05); }
  .tree-item.active {
    background: rgba(122,162,247,0.15);
    color: #c0caf5;
  }
  .tree-file-icon { color: #565f89; font-size: 0.85rem; }
  .tree-folder-icon { color: #e0af68; font-size: 0.7rem; }
  .tree-item a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }
  .tree-item:hover a { color: #7aa2f7; }

  /* ── 编辑器 ── */
  .ide-editor {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* 标签栏 */
  .ide-tabs {
    background: #16161e;
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    flex-shrink: 0;
  }
  .tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: 0.78rem;
    color: #565f89;
    border-right: 1px solid rgba(255,255,255,0.05);
    user-select: none;
  }
  .tab.active {
    background: #1a1b26;
    color: #c0caf5;
    border-top: 1px solid #7aa2f7;
  }
  .tab-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #e0af68;
  }

  /* 面包屑 */
  .ide-breadcrumb {
    padding: 5px 16px;
    font-size: 0.72rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
  }
  .bc-dim { color: #3b4261; }
  .bc-sep { color: #3b4261; }
  .bc-current { color: #737aa2; }

  /* 正文 + 行号 */
  .ide-content {
    display: flex;
    flex: 1;
    overflow-y: auto;
  }
  .line-numbers {
    padding: 16px 0;
    min-width: 40px;
    text-align: right;
    padding-right: 14px;
    display: flex;
    flex-direction: column;
    font-size: 0.78rem;
    line-height: 1.85;
    color: #3b4261;
    user-select: none;
    flex-shrink: 0;
    border-right: 1px solid rgba(255,255,255,0.04);
  }

  .editor-body {
    padding: 16px 24px;
    font-size: clamp(0.85rem, 2vw, 0.95rem);
    line-height: 1.85;
    color: #c0caf5;
    flex: 1;
  }
  .editor-body p { margin: 0; }

  .md-marker   { color: #565f89; }
  .md-h1       { color: #f7768e; font-weight: 700; font-size: 1.1em; }
  .md-h2       { color: #e0af68; font-weight: 600; }
  .md-blockquote {
    color: #737aa2;
    border-left: 2px solid #3b4261;
    padding-left: 10px;
    margin-left: 2px;
  }
  .md-hr       { color: #3b4261; }
  .md-li       { padding-left: 4px; }
  .md-comment  { color: #565f89; }
  .md-link     { color: #7dcfff; text-decoration: none; }
  .md-link:hover { text-decoration: underline; }
  .md-link-inline { color: #7aa2f7; text-decoration: none; }
  .md-link-inline:hover { text-decoration: underline; }
  .md-link-url { color: #9ece6a; }
  .md-blank    { line-height: 1; height: 0.6em; }

  .hl {
    color: #ff9e64;
    font-weight: 700;
  }

  /* 状态栏 */
  .ide-statusbar {
    background: #7aa2f7;
    padding: 3px 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    color: #1a1b26;
    font-weight: 500;
    flex-shrink: 0;
  }
  .status-left, .status-right {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .status-branch { font-weight: 700; }

  /* ── 响应式 ── */
  @media (max-width: 600px) {
    .ide-layout { grid-template-columns: 1fr; }
    .ide-activity-bar, .ide-sidebar { display: none; }
  }
</style>
