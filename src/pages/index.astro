---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const cards = [
  { title: '文章',   desc: '长文，值得反复阅读。',   href: '/blog' },
  { title: '笔记',   desc: '日常碎片与即时观察。',   href: '/psychology/human-vs-ai/' },
  { title: '工具箱', desc: '正在用的工具推荐。',    href: '/tools' },
];
---

<StarlightPage
  frontmatter={{ title: '陈的笔记', description: '这里不用登录，没有广告，没有算法，没有审查。你不是产品。', tableOfContents: false }}
  hasSidebar={false}
  headings={[]}
>
  <div class="home">
    <div class="hero">
      <h1>你好，人类。<br />欢迎你选择走进来。</h1>

      <p class="sub">
        这里不用登录，没有广告，没有算法，没有审查。你不是产品。
        <a href="/about">了解这个站点 →</a>
      </p>

      <p class="intro">逛逛看。</p>
    </div>

    <div class="cards">
      {cards.map(card => (
        <a href={card.href} class="card">
          <span class="card-title">{card.title}</span>
          <span class="card-desc">{card.desc}</span>
        </a>
      ))}
    </div>
  </div>
</StarlightPage>

<style>
  /* 隐藏 Starlight 自动生成的页面标题和 hero 分隔线 */
  :global(#_top) { display: none; }
  :global(.sl-markdown-content > hr:first-of-type) { display: none; }

  .home { margin-top: -1rem; }

  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
  }

  :global(.sl-markdown-content) .hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--sl-color-white) !important;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
  }

  .sub {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    line-height: 1.75;
    max-width: 520px;
  }

  .sub a {
    color: var(--sl-color-accent);
    text-decoration: none;
    margin-left: 0.4em;
    transition: opacity 0.15s;
  }
  .sub a:hover { opacity: 0.8; }

  .intro {
    margin-top: 2rem;
    font-size: 0.95rem;
    color: var(--sl-color-gray-4);
    letter-spacing: 0.05em;
  }

  /* ── Cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .cards { grid-template-columns: 1fr; }
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-gray-5);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sl-color-accent-high);
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }
</style>
