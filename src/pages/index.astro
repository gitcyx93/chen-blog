---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const cards = [
  { title: '文章',   desc: '长文，值得反复阅读。',   href: '/blog' },
  { title: '笔记',   desc: '日常碎片与即时观察。',   href: '/psychology/human-vs-ai/' },
  { title: '工具箱', desc: '正在用的工具推荐。',    href: '/tools' },
];
---

<StarlightPage
  frontmatter={{ title: '陈的笔记', description: '这里不用登录，没有广告，没有算法，没有审查。你不是产品。', tableOfContents: false }}
  hasSidebar={false}
  headings={[]}
>
  <div class="home">
    <div class="hero">

      <!-- ── 终端打字机 ── -->
      <div class="terminal-window">
        <div class="terminal-titlebar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="terminal-title">~/ 陈的笔记</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line path-line">
            <span class="path-user">yuxiang</span><span class="path-at">@</span><span class="path-host">blog</span><span class="path-sep"> </span><span class="path-dir">~/陈的笔记</span>
          </div>
          <div class="terminal-line">
            <span class="prompt">❯&nbsp;</span><span id="typed-text"></span><span class="cursor" id="typed-cursor">█</span>
          </div>
        </div>
      </div>

      <!-- 遮罩消散 -->
      <p class="sub" id="sub-text">
        这里不用登录，没有广告，没有算法，没有审查。你不是产品。
        <a href="/about">了解这个站点 →</a>
      </p>

      <!-- 向上滑入 -->
      <p class="intro" id="intro-text">逛逛看。</p>
    </div>

    <div class="cards">
      {cards.map(card => (
        <a href={card.href} class="card">
          <span class="card-title">{card.title}</span>
          <span class="card-desc">{card.desc}</span>
        </a>
      ))}
    </div>
  </div>
</StarlightPage>

<script>
  const typedEl = document.getElementById('typed-text');
  const cursor  = document.getElementById('typed-cursor');
  const subEl   = document.getElementById('sub-text');
  const introEl = document.getElementById('intro-text');
  if (!typedEl || !cursor || !subEl || !introEl) throw new Error('elements missing');

  const segments = [
    { text: '你好，人类，欢迎你', hl: false },
    { text: '选择',              hl: true  },
    { text: '走进来',            hl: false },
  ];

  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  async function run() {
    await sleep(300);

    for (const seg of segments) {
      if (seg.hl) await sleep(420);
      for (const ch of [...seg.text]) {
        const span = document.createElement('span');
        if (seg.hl) span.className = 'hl';
        span.textContent = ch;
        typedEl.appendChild(span);
        await sleep(seg.hl ? 160 : 65 + Math.random() * 55);
      }
      if (seg.hl) await sleep(380);
    }

    // 打完 → 遮罩消散
    await sleep(350);
    subEl.classList.add('reveal');

    // 再停顿 → 向上滑入 (intro)
    await sleep(500);
    introEl.classList.add('slide-up');

    // 卡片依次滑入
    await sleep(300);
    document.querySelectorAll<HTMLElement>('.card').forEach((card, i) => {
      setTimeout(() => card.classList.add('slide-up'), i * 120);
    });
  }

  run();
</script>

<style>
  /* ══ 隐藏 Starlight 自动元素 ══ */
  :global(header.header) { display: none; }
  :global(.main-frame) { padding-top: 0 !important; }
  :global(#_top) { display: none; }
  :global(.sl-markdown-content > hr:first-of-type) { display: none; }

  .home { margin-top: -1rem; }

  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
  }

  /* ══ 终端窗口 ══ */
  .terminal-window {
    width: min(680px, 100%);
    background: #1e2029;
    border-radius: 10px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.06);
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .terminal-titlebar {
    background: #2d303e;
    padding: 10px 16px;
    display: flex;
    gap: 7px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: #6b7280;
    user-select: none;
  }

  .terminal-body {
    padding: 18px 22px 24px;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, 'Courier New', monospace;
    font-size: clamp(0.95rem, 2.4vw, 1.1rem);
    line-height: 1.8;
    color: #cdd6f4;
  }

  .terminal-line {
    display: block;
  }

  /* 路径行 */
  .path-line {
    margin-bottom: 2px;
  }
  .path-user  { color: #a6e3a1; }
  .path-at    { color: #6b7280; }
  .path-host  { color: #89b4fa; }
  .path-sep   { color: #6b7280; }
  .path-dir   { color: #89dceb; }

  .prompt {
    color: #a6e3a1;
    user-select: none;
  }

  /* 强调词（:global 因 JS 动态创建无 Astro 作用域属性） */
  :global(.hl) {
    color: #f9e2af;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .cursor {
    color: #cba6f7;
    animation: blink 0.85s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ══ 遮罩消散 (.sub) ══ */
  .sub {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    line-height: 1.75;
    max-width: 520px;
    opacity: 0;
    filter: blur(6px);
    transition: opacity 0.9s ease-out, filter 0.9s ease-out;
  }
  .sub.reveal {
    opacity: 1;
    filter: blur(0);
  }

  .sub a {
    color: var(--sl-color-accent);
    text-decoration: none;
    margin-left: 0.4em;
    transition: opacity 0.15s;
  }
  .sub a:hover { opacity: 0.8; }

  /* ══ 向上滑入 (.intro) ══ */
  .intro {
    margin-top: 2rem;
    font-size: 0.95rem;
    color: var(--sl-color-gray-4);
    letter-spacing: 0.05em;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.65s ease-out, transform 0.65s ease-out;
  }
  .intro.slide-up {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .cards { grid-template-columns: 1fr; }
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s,
                opacity 0.6s ease-out, transform 0.6s ease-out;
    opacity: 0;
    transform: translateY(20px);
  }
  .card.slide-up {
    opacity: 1;
    transform: translateY(0);
  }

  .card:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-gray-5);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sl-color-accent-high);
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }
</style>
