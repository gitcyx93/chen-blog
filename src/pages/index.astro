---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const cards = [
  { title: '文章',   desc: '长文，值得反复阅读。',   href: '/blog' },
  { title: '笔记',   desc: '日常碎片与即时观察。',   href: '/psychology/human-vs-ai/' },
  { title: '工具箱', desc: '正在用的工具推荐。',    href: '/tools' },
];
---

<StarlightPage
  frontmatter={{ title: '陈的笔记', description: '这里不用登录，没有广告，没有算法，没有审查。你不是产品。', tableOfContents: false }}
  hasSidebar={false}
  headings={[]}
>
  <div class="home">
    <div class="hero">

      <!-- ── 终端打字机（替换原 h1） ── -->
      <div class="terminal-window">
        <div class="terminal-titlebar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <div class="terminal-body">
          <span class="prompt">❯&nbsp;</span><span id="typed-text"></span><span class="cursor" id="typed-cursor">█</span>
        </div>
      </div>

      <p class="sub">
        这里不用登录，没有广告，没有算法，没有审查。你不是产品。
        <a href="/about">了解这个站点 →</a>
      </p>

      <p class="intro">逛逛看。</p>
    </div>

    <div class="cards">
      {cards.map(card => (
        <a href={card.href} class="card">
          <span class="card-title">{card.title}</span>
          <span class="card-desc">{card.desc}</span>
        </a>
      ))}
    </div>
  </div>
</StarlightPage>

<script>
  const typedEl = document.getElementById('typed-text');
  const cursor  = document.getElementById('typed-cursor');
  if (!typedEl || !cursor) throw new Error('typed elements missing');

  const segments = [
    { text: '你好，人类，欢迎你', hl: false },
    { text: '选择',              hl: true  },
    { text: '走进来',            hl: false },
  ];

  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  async function run() {
    await sleep(300);

    for (const seg of segments) {
      if (seg.hl) await sleep(420);  // "选择"前停顿

      for (const ch of [...seg.text]) {
        const span = document.createElement('span');
        if (seg.hl) span.className = 'hl';
        span.textContent = ch;
        typedEl.appendChild(span);
        await sleep(seg.hl ? 160 : 65 + Math.random() * 55);
      }

      if (seg.hl) await sleep(380);  // "选择"后停顿
    }
    // 打完后光标持续闪烁，不消失
  }

  run();
</script>

<style>
  /* ══ 隐藏 Starlight 自动元素 ══ */
  :global(header.header) { display: none; }
  :global(.main-frame) { padding-top: 0 !important; }
  :global(#_top) { display: none; }
  :global(.sl-markdown-content > hr:first-of-type) { display: none; }

  .home { margin-top: -1rem; }

  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
  }

  /* ── 终端窗口（内嵌 hero） ── */
  .terminal-window {
    width: min(520px, 100%);
    background: #3b4252;
    border-radius: 10px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .terminal-titlebar {
    background: #434c5e;
    padding: 10px 14px;
    display: flex;
    gap: 7px;
    align-items: center;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot-red    { background: #bf616a; }
  .dot-yellow { background: #ebcb8b; }
  .dot-green  { background: #a3be8c; }

  .terminal-body {
    padding: 20px 24px 26px;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, 'Courier New', monospace;
    font-size: clamp(1.05rem, 2.6vw, 1.25rem);
    line-height: 1.7;
    color: #d8dee9;
    min-height: 3.2em;
  }

  .prompt {
    color: #a3be8c;
    user-select: none;
  }

  /* 强调词（:global 因 JS 动态创建，无 Astro 作用域属性） */
  :global(.hl) {
    color: #ebcb8b;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .cursor {
    color: #88c0d0;
    animation: blink 0.85s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ── Sub / Intro ── */
  .sub {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    line-height: 1.75;
    max-width: 520px;
  }

  .sub a {
    color: var(--sl-color-accent);
    text-decoration: none;
    margin-left: 0.4em;
    transition: opacity 0.15s;
  }
  .sub a:hover { opacity: 0.8; }

  .intro {
    margin-top: 2rem;
    font-size: 0.95rem;
    color: var(--sl-color-gray-4);
    letter-spacing: 0.05em;
  }

  /* ── Cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .cards { grid-template-columns: 1fr; }
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-gray-5);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sl-color-accent-high);
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }
</style>
