---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PhilosophyTree from '../components/PhilosophyTree';
---

<StarlightPage
  frontmatter={{ title: '哲学谱系', description: '从古希腊到当代——主要哲学流派与代表人物的树状谱系图', tableOfContents: false }}
  hasSidebar={false}
  headings={[]}
>
  <div class="philosophy-page">
    <div class="tree-wrapper">
      <PhilosophyTree client:load />
    </div>
  </div>
</StarlightPage>

<style>
  /* Break out of Starlight's 44rem content column */
  :global(.sl-markdown-content:has(.philosophy-page)) {
    max-width: none;
    padding: 0;
  }

  .philosophy-page {
    width: 100%;
  }

  .tree-wrapper {
    width: 100%;
    overflow-x: auto;
  }
</style>
