---
export const prerender = true;
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

const toTs = (value?: string) => {
  const ts = value ? Date.parse(value) : NaN;
  return Number.isNaN(ts) ? 0 : ts;
};

const notes = (await getCollection('docs'))
  .sort((a, b) => toTs(b.data.date) - toTs(a.data.date));
---

<StarlightPage
  frontmatter={{ title: '笔记', description: '所有笔记都在这里；其中一部分会被选为文章。' }}
  hasSidebar={false}
  headings={[]}
>
  {notes.length === 0 ? (
    <p>还没有内容，先上传一篇笔记吧。</p>
  ) : (
    <ul>
      {notes.map((entry) => (
        <li>
          <a href={`/${entry.slug}/`}>{entry.data.title}</a>
          {entry.data.article ? <span> · 文章已选中</span> : null}
          {entry.data.date ? <span> · {entry.data.date}</span> : null}
        </li>
      ))}
    </ul>
  )}
</StarlightPage>
